package com.jwt.demo;

import io.jsonwebtoken.Claims;
import io.jsonwebtoken.ExpiredJwtException;
import io.jsonwebtoken.JwtException;
import io.jsonwebtoken.Jwts;
import java.util.Date;

public class JwtVerifier {

    private final JwtUtil jwtUtil;
    
    public JwtVerifier(JwtUtil jwtUtil) {
        this.jwtUtil = jwtUtil;
    }
    
    // ============================================
    // VERIFY — Signature valid? (Cryptographic)
    // ============================================
    public boolean verifySignature(String token) {
        try {
            Jwts.parser()
                .verifyWith(jwtUtil.getSecretKey())
                .build()
                .parseSignedClaims(token); // Signature check
            
            System.out.println("[VERIFY] Signature valid!");
            return true;
        } catch (JwtException e) {
            System.out.println("[VERIFY] FAILED: " + e.getMessage());
            return false;
        }
    }
    
    // ============================================
    // VALIDATE — Claims valid-? (Business rules)
    // ============================================
    public boolean validate Claims(String token) {
        try {
            Claims claims = Jwts.parser()
                .verifyWith(jwtUtil.getSecretKey())
                .build()
                .parseSignedClaims(token)
                .getPayload();
            
            // 1. Expiry check
            Date exp = claims.getExpiration();
            if (exp.before(new Date())) {
                System.out.println("[VALIDATE] Token expired!");
                return false;
            }
            
            // 2. Issuer check
            String iss = claims.getIssuer();
            if (!"myapp".equals(iss)) {
                System.out.println("[VALIDATE] Wrong issuer: " + iss);
                return false;
            }
            
            // 3. Subject check
            String sub = claims.getSubject();
            if (sub == null || sub.isEmpty()) {
                System.out.println("[VALIDATE] Missing subject!");
                return false;
            }
            
            System.out.println("[VALIDATE] All claims valid!");
            System.out.println("  Subject : " + sub);
            System.out.println("  Issuer  : " + iss);
            System.out.println("  Expires : " + exp);
            System.out.println("  Role    : " + claims.get("role"));
            return true;
            
        } catch (ExpiredJwtException e) {
            System.out.println("[VALIDATE] Token expired!");
            return false;
        } catch (JwtException e) {
            System.out.println("[VALIDATE] Invalid token: " + e.getMessage());
            return false;
        }
    }
}