	<!-- Servlets -->
	<servlet>
		<servlet-name>DashboardServlet</servlet-name>
		<servlet-class>com.workdrive.organizer.servlet.DashboardServlet</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<servlet-name>OrganizeServlet</servlet-name>
		<servlet-class>com.workdrive.organizer.servlet.OrganizeServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>FilesApiServlet</servlet-name>
		<servlet-class>com.workdrive.organizer.servlet.FilesApiServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>DownloadServlet</servlet-name>
		<servlet-class>com.workdrive.organizer.servlet.DownloadServlet</servlet-class>
	</servlet>


	<servlet-mapping>
		<servlet-name>DashboardServlet</servlet-name>
		<url-pattern>/</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>OrganizeServlet</servlet-name>
		<url-pattern>/organize</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>FilesApiServlet</servlet-name>
		<url-pattern>/api/files</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>DownloadServlet</servlet-name>
		<url-pattern>/download</url-pattern>
	</servlet-mapping>

	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
	</welcome-file-list>
</web-app>