package com.jwt.refresh;

import java.time.Instant;
import java.util.Map;
import java.util.UUID;
import java.util.concurrent.ConcurrentHashMap;

/**
 * Refresh token-ஐ store + validate பண்ற class.
 *
 * Production: Redis அல்லது DB table use பண்ணு
 *   Table: (id, userId, token, expiresAt, revoked)
 *
 * இங்க: in-memory ConcurrentHashMap (demo only)
 */
public class RefreshTokenStore {

    // token string -> metadata
    private final Map<String, RefreshEntry> store = new ConcurrentHashMap<>();
    
    private static final long TTL_DAYS = 7;
    
    // ========================================
    // Entry record
    // ========================================
    public static class RefreshEntry {
        public final String  userId;
        public final Instant expiresAt;
        public       boolean revoked;
        
        public RefreshEntry(String userId) {
            this.userId    = userId;
            this.expiresAt = Instant.now().plusSeconds(TTL_DAYS * 86400);
            this.revoked   = false;
        }
        
        public boolean isExpired() {
            return Instant.now().isAfter(expiresAt);
        }
        
        public boolean isValid() {
            return !revoked && !isExpired();
        }
    }
    
    // ========================================
    // Save new refresh token
    // ========================================
    public String save(String userId) {
        // UUID — random, unpredictable
        String token = UUID.randomUUID().toString();
        store.put(token, new RefreshEntry(userId));
        System.out.println("[STORE] Saved refresh token for: " + userId);
        return token;
    }
    
    // ========================================
    // Validate — valid-ஆ? userId திரும்ப கொடு
    // ========================================
    public String validate(String refreshToken) {
        RefreshEntry entry = store.get(refreshToken);
        
        if (entry == null) {
            throw new RuntimeException("Refresh token not found!");
        }
        if (entry.revoked) {
            throw new RuntimeException("Refresh token revoked!");
        }
        if (entry.isExpired()) {
            store.remove(refreshToken);
            throw new RuntimeException("Refresh token expired!");
        }
        
        return entry.userId;
    }
    
    // ========================================
    // Revoke — logout / token rotation
    // ========================================
    public void revoke(String refreshToken) {
        RefreshEntry entry = store.get(refreshToken);
        if (entry != null) {
            entry.revoked = true;
            System.out.println("[STORE] Revoked token for: " + entry.userId);
        }
    }
    
    // ========================================
    // Revoke all — user-ன் எல்லா sessions
    // ========================================
    public void revokeAllForUser(String userId) {
        store.entrySet()
             .stream()
             .filter(e -> e.getValue().userId.equals(userId))
             .forEach(e -> e.getValue().revoked = true);
        System.out.println("[STORE] All sessions revoked for: " + userId);
    }
    
    public int activeCount() {
        return (int) store.values().stream().filter(e -> e.isValid()).count();
    }
}