package com.jwt.refresh;

import io.jsonwebtoken.Claims;

public class RefreshTokenDemo {

    public static void main(String[] args) throws InterruptedException {
        
        TokenService    service    = new TokenService();
        AuthController  controller = new AuthController(service);
        
        sep("1. LOGIN");
        TokenPair tokens = controller.login("krishna@tp.com", "pass123");
        System.out.println(tokens);
        
        String accessToken  = tokens.getAccessToken();
        String refreshToken = tokens.getRefreshToken();
        
        sep("2. CALL PROTECTED API (valid token)");
        String res1 = controller.protectedEndpoint(accessToken);
        System.out.println("Response: " + res1);
        
        sep("3. SIMULATE TOKEN REFRESH");
        // Real-ல 401 வந்தா client automatically refresh பண்ணும்
        System.out.println("Simulating access token expiry...");
        TokenPair newTokens = controller.refresh(refreshToken);
        System.out.println("New " + newTokens);
        
        String newAccessToken  = newTokens.getAccessToken();
        String newRefreshToken = newTokens.getRefreshToken();
        
        sep("4. USE NEW ACCESS TOKEN");
        String res2 = controller.protectedEndpoint(newAccessToken);
        System.out.println("Response: " + res2);
        
        sep("5. OLD REFRESH TOKEN REUSE (Rotation test)");
        // Token rotation: old refresh token இப்போ invalid!
        try {
            controller.refresh(refreshToken); // OLD token
        } catch (RuntimeException e) {
            System.out.println("CORRECT — " + e.getMessage());
            System.out.println("Token theft detected! (same token reused)");
        }
        
        sep("6. LOGOUT");
        String logoutRes = controller.logout(newRefreshToken);
        System.out.println(logoutRes);
        
        sep("7. REFRESH AFTER LOGOUT (should fail)");
        try {
            controller.refresh(newRefreshToken);
        } catch (RuntimeException e) {
            System.out.println("CORRECT — " + e.getMessage());
        }
        
        sep("8. ACTIVE SESSIONS");
        int active = service.getRefreshStore().activeCount();
        System.out.println("Active refresh tokens: " + active + " (should be 0)");
    }
    
    private static void sep(String title) {
        System.out.println("\n====== " + title + " ======");
    }
}