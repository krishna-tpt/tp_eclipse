	public List<Integer> getUsers(int ad_org_id) throws SQLException {
		logger.debug("Fetching users for organization: ad_org_id={}", ad_org_id);
		List<Integer> ad_user_ids = new ArrayList<>();
		String query = "SELECT distinct au.ad_user_id FROM ad_user au "
				+ "INNER JOIN ad_user_roles ur ON au.ad_user_id = ur.ad_user_id "
				+ "WHERE au.ad_org_id = ? AND au.isactive = 'Y' AND ur.isactive = 'Y' ";
		try (PreparedStatement ps = conn.prepareStatement(query)) {
			ps.setInt(1, ad_org_id);
			ResultSet rs = ps.executeQuery();
			while (rs.next()) {
				ad_user_ids.add(rs.getInt(1));
			}
			logger.debug("Retrieved {} users for organization: ad_org_id={}", ad_user_ids.size(), ad_org_id);
		} catch (SQLException e) {
			logger.error("Error fetching users for organization: ad_org_id={}, error: {}", ad_org_id, e.getMessage(),
					e);
			throw e;
		}
		return ad_user_ids;
	}

