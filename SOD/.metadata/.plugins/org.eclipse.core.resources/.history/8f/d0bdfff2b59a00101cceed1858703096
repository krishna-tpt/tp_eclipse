	public ResultSet getfinalQueryResultSet(int ad_org_id) throws SQLException {
		logger.debug("Executing final query for organization: ad_org_id={}", ad_org_id);
		String sql = "SELECT AD_org_id, Source, Sod_Matrix_Function, Documentno, Creation_Date, Currency_Code, Description, Quantity, Unit_Price, Total_Price, Debit_Amount, Credit_Amount, LocalAccount, Third_Party, Third_Party_Number, User_Id, User_Name, Record_ID "
