	public void callProcedure(String procName, int orgId, int userId) throws SQLException {
		callProcedure(procName, orgId, userId, null, null);
	}

	public void callProcedure(String procName, int orgId, int userId, String startDate, String endDate)
			throws SQLException {
		logger.debug("Calling procedure {} for orgId={}, userId={}, startDate={}, endDate={}", procName, orgId, userId,
				startDate, endDate);
		String sql;
		CallableStatement cs = null;
		try {
			if (startDate != null && endDate != null) {
				sql = "{call " + procName + "(?,?,TO_DATE(?, '" + Main.dateformat + "'),TO_DATE(?,'" + Main.dateformat
						+ "'))}";
				cs = conn.prepareCall(sql);
				cs.setInt(1, orgId);
				cs.setInt(2, userId);
				cs.setString(3, startDate);
				cs.setString(4, endDate);
			} else {
				sql = "{call " + procName + "(?, ?)}";
				cs = conn.prepareCall(sql);
				cs.setInt(1, orgId);
				cs.setInt(2, userId);
			}
			cs.execute();
			logger.debug("Procedure {} executed successfully", procName);
			if (!conn.getAutoCommit()) {
				conn.commit();
				logger.debug("Transaction committed for procedure {}", procName);
			}
		} catch (SQLException e) {
			logger.error("Error executing procedure {}: {}", procName, e.getMessage(), e);
			if (conn != null) {
				try {
					conn.rollback();
					logger.debug("Transaction rolled back due to error in procedure {}", procName);
					System.out.println("Transaction rolled back due to error");
				} catch (SQLException rollbackEx) {
					logger.error("Error during rollback: {}", rollbackEx.getMessage(), rollbackEx);
					System.err.println("Error during rollback: " + rollbackEx.getMessage());
				}
			}
			throw e;
		} finally {
			if (cs != null) {
				try {
					cs.close();
					logger.trace("CallableStatement closed for procedure {}", procName);
				} catch (SQLException e) {
					logger.error("Error closing CallableStatement: {}", e.getMessage(), e);
					System.err.println("Error closing CallableStatement: " + e.getMessage());
				}
			}
		}
	}

	public void getFinalQueryResult(int ad_org_id) throws SQLException, IOException {
		logger.info("Generating final query result for organization: ad_org_id={}", ad_org_id);
		DateTimeFormatter dateFormatter = DateTimeFormatter.ofPattern("yyyy-MM-dd");
		String filePath = getFileName(ad_org_id);
		logger.debug("Preparing to write Excel file: {}", filePath);

		// Ensure the directory exists
		Path fileDir = Paths.get(filePath).getParent();
		try {
			Files.createDirectories(fileDir);
			logger.debug("Ensured directory exists: {}", fileDir);
		} catch (IOException e) {
			logger.error("Failed to create directory {}: {}", fileDir, e.getMessage(), e);
			throw e;
		}

		ResultSet rs = getfinalQueryResultSet(ad_org_id);
		if (!rs.next()) {
			logger.warn("No results found for organization: ad_org_id={}", ad_org_id);
			return;
		}

		String orgName = getOrgName(ad_org_id);
		if (orgName == null) {
			logger.error("Organization name not found for ad_org_id={}", ad_org_id);
			throw new SQLException("Organization name not found for ad_org_id=" + ad_org_id);
		}

		try (Workbook workbook = new XSSFWorkbook()) {
			logger.debug("Excel file writing started...");
			org.apache.poi.ss.usermodel.Sheet sheet = workbook.createSheet("Audit Report");
			String[] headers = { "ORGANIZATION", "SOURCE", "SOD_MATRIX_FUNCTION", "DOCUMENTNO", "CREATION/UPDATION",
					"CURRENCY_CODE", "DESCRIPTION", "QUANTITY", "UNIT_PRICE", "TOTAL_PRICE", "DEBIT_AMOUNT",
					"CREDIT_AMOUNT", "LOCAL_ACCOUNT", "THIRD_PARTY", "THIRD_PARTY_NUMBER", "USER_ID", "USER_NAME","RECORD_ID"};
			Row headerRow = sheet.createRow(0);
			for (int i = 0; i < headers.length; i++) {
				Cell cell=headerRow.createCell(i);
				cell.setCellValue(headers[i]);
			}
			int rowIndex = 1;
			do {
				Row row = sheet.createRow(rowIndex++);
				int col = 0;
				row.createCell(col++).setCellValue(orgName);
				for (int i = 2; i <= 17; i++) {
					Object value = rs.getObject(i);
					if (value != null) {
						if (value instanceof java.sql.Timestamp) {
							String formattedDate = ((java.sql.Timestamp) value).toLocalDateTime().toLocalDate()
									.format(dateFormatter);
							row.createCell(col++).setCellValue(formattedDate);
						} else if (value instanceof java.sql.Date) {
							String formattedDate = ((java.sql.Date) value).toLocalDate().format(dateFormatter);
							row.createCell(col++).setCellValue(formattedDate);
						} else {
							row.createCell(col++).setCellValue(value.toString());
						}
					} else {
						row.createCell(col++).setCellValue("");
					}
				}
			} while (rs.next());
			for (int i = 0; i < headers.length; i++) {
				sheet.autoSizeColumn(i);
			}
			try (FileOutputStream fileOut = new FileOutputStream(filePath)) {
				workbook.write(fileOut);
				logger.info("Excel file created successfully: {}", filePath);
				System.out.println("Excel file created: " + filePath);
			}
		} catch (IOException e) {
			logger.error("Error writing Excel file {}: {}", filePath, e.getMessage(), e);
			throw e;
		}
	}

	public String getFileName(int ad_org_id) throws SQLException {
		String orgShortName = getOrgShortName(ad_org_id);
		String directory = prop.getProperty(String.valueOf(ad_org_id));
		String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("MM_dd_yyyy"));
		String fileName = String.format("SOD_AUDIT_REPORT_%s_%s.xlsx", orgShortName, timestamp);
		String filePath = Paths.get(directory, fileName).toString();
		return filePath;
	}

	public String getOrgName(int ad_org_id) throws SQLException {
		logger.debug("Fetching organization name for ad_org_id={}", ad_org_id);
		String query = "SELECT name FROM ad_org WHERE ad_org_id = ?";
		try (PreparedStatement ps = conn.prepareStatement(query)) {
			ps.setInt(1, ad_org_id);
			ResultSet rs = ps.executeQuery();
			if (rs.next()) {
				String orgName = rs.getString(1);
				logger.trace("Retrieved organization name: {} for ad_org_id={}", orgName, ad_org_id);
				return orgName;
			}
		} catch (SQLException e) {
			logger.error("Error fetching organization name for ad_org_id={}: {}", ad_org_id, e.getMessage(), e);
			throw e;
		}
		return null;
	}

	public String getUserName(int ad_org_id, int ad_user_id) throws SQLException {
		logger.debug("Fetching user name for ad_org_id={}, ad_user_id={}", ad_org_id, ad_user_id);
		String query = "SELECT COALESCE(name, value) FROM ad_user WHERE ad_org_id = ? AND ad_user_id = ?";
		try (PreparedStatement ps = conn.prepareStatement(query)) {
			ps.setInt(1, ad_org_id);
			ps.setInt(2, ad_user_id);
			ResultSet rs = ps.executeQuery();
			if (rs.next()) {
				String userName = rs.getString(1);
				logger.trace("Retrieved user name: {} for ad_user_id={}", userName, ad_user_id);
				return userName;
			}
		} catch (SQLException e) {
			logger.error("Error fetching user name for ad_user_id={}: {}", ad_user_id, e.getMessage(), e);
			throw e;
		}
		return null;
	}

