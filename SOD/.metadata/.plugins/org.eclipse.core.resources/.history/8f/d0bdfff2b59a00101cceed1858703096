		} catch (SQLException e) {
			logger.error("Error executing final query for ad_org_id={}: {}", ad_org_id, e.getMessage(), e);
			throw e;
		}
	}

	public void addLog(int ad_org_id, int ad_user_id, String user_name, LocalDateTime startTime) throws SQLException {
		logger.debug("Adding log data: user_name={}, ad_user_id={}", user_name, ad_user_id);
		String sql = "INSERT INTO Z_SOD_AUDIT_LOG (AD_ORG_ID, AD_USER_ID, USER_Name, START_TIME, END_TIME, DURATION_SECONDS) "
				+ "Values (?,?,?,?,?,?)";
		try (PreparedStatement ps = conn.prepareStatement(sql)) {
			LocalDateTime endTime = LocalDateTime.now();
			Duration duration = Duration.between(startTime, endTime);
			ps.setInt(1, ad_org_id);
			ps.setInt(2, ad_user_id);
			ps.setString(3, user_name);
			ps.setTimestamp(4, Timestamp.valueOf(startTime));
			ps.setTimestamp(5, Timestamp.valueOf(endTime));
			ps.setLong(6, duration.getSeconds());
			int count = ps.executeUpdate();
			logger.debug("Inserted {} row(s) into Z_SOD_AUDIT_LOG for ad_user_id={}", count, ad_user_id);
			if (!conn.getAutoCommit()) {
				conn.commit();
				logger.debug("Transaction committed for add user log ad_user_id={}", ad_user_id);
			}
		} catch (SQLException e) {
			logger.error("Error adding log for ad_user_id={}: {}", ad_user_id, e.getMessage(), e);
			throw e;
		}
	}

